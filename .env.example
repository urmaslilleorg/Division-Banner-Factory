# Session secret — must be 32+ characters, random string
# Generate with: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-32-plus-char-random-string

# Airtable
AIRTABLE_API_KEY=pat...

# App domain (for subdomain routing)
# Production: menteproduction.com
# Local dev: localhost:3000
NEXT_PUBLIC_APP_DOMAIN=menteproduction.com

# Figma (optional — for Asset Library viewer in Admin)
FIGMA_ACCESS_TOKEN=figd_...

# Vercel Blob (for banner image storage)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Resend (email notifications)
# Get API key from resend.com → API Keys
RESEND_API_KEY=re_...
# From address — use onboarding@resend.dev until menteproduction.com domain is verified
RESEND_FROM_EMAIL=notifications@menteproduction.com

# ── AI features (optional) ────────────────────────────────────────────────────
# Required for "Create from video" (AI mode) and "Create from existing banners"
# flows. When not set, AI buttons are hidden and the routes return 503.
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
# Set to "1" whenever ANTHROPIC_API_KEY is set — exposes AI mode buttons in
# client components (which cannot read server-only env vars directly)
NEXT_PUBLIC_HAS_ANTHROPIC_KEY=1
